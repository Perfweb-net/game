DATABASE_URL="file:./prisma/dev.db"
PORT=3001

# --- AI Tactical Advisor (Senior Dev) ---------------------------------------
# Sans clé : l'advisor tourne en mode heuristique local (gratuit, aucune config).
# Pour des conseils rédigés par un vrai LLM (gratuit, sans carte bancaire) :
#   1. Crée une clé sur https://console.groq.com/keys  (gratuit)
#   2. Décommente la ligne ci-dessous et colle ta clé.
ADVISOR_API_KEY=
#
# Optionnel — fonctionne avec n'importe quelle API OpenAI-compatible :
# ADVISOR_API_URL=https://api.groq.com/openai/v1/chat/completions
# ADVISOR_MODEL=llama-3.1-8b-instant

